# --- TensorRT engines (built per-device on Jetson) ---
*.engine

# --- Large model weights (manage separately if needed) ---
*.pt
*.pth

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# --- Logs / results (keep folders via .gitkeep, ignore contents) ---
logs/*
!logs/.gitkeep
results/*.png
results/*.jpg
results/*.csv
results/*.npy

# --- Data ---
data/*
!data/.gitkeep

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo